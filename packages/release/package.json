{
  "name": "@vyron/release",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": {
        "import": "./dist/index.d.mts",
        "require": "./dist/index.d.cts"
      },
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "typecheck": "vp check --no-fmt --no-lint",
    "test": "vitest run",
    "release": "bumpp -y --all"
  },
  "dependencies": {
    "prompts": "^2.4.2",
    "semver": "^7.7.1"
  },
  "devDependencies": {
    "@types/semver": "^7.5.8",
    "typescript": "^5.7.2",
    "vite-plus": "^0.1.24",
    "vitest": "^4.1.8"
  }
}
