{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": false,
  "singleQuote": true,
  "printWidth": 80,
  "sortPackageJson": false,
  "ignorePatterns": [
    ".trellis/**",
    ".agent/**",
    ".agents/**",
    ".claude/**",
    ".codex/**",
    ".gemini/**",
    ".github/**",
    "packages/*/CHANGELOG.md",
    "dist/",
    "temp/",
    "LICENSE.md",
    "pnpm-lock.yaml",
    "pnpm-workspace.yaml"
  ]
}