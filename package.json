{
  "name": "vii",
  "license": "MIT",
  "author": "vyron",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vfiee/project-boilerplate.git"
  },
  "type": "module",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "postinstall": "simple-git-hooks",
    "format": "vp check --fix",
    "lint": "vp check",
    "dev": "pnpm -r --parallel --filter='./packages/cli' run dev",
    "build": "pnpm -r --filter='./packages/*' run build",
    "docs:dev": "pnpm --filter vii-docs dev",
    "docs:build": "pnpm --filter vii-docs build",
    "typecheck": "vp check --no-fmt --no-lint",
    "stackblitz:cli": "pnpm build && pnpm --filter @vyron/cli link --global && node scripts/welcome-cli.js",
    "stackblitz:release": "pnpm build && pnpm --filter @vyron/cli link --global && node scripts/welcome-release.js",
    "stackblitz:storage": "pnpm build && pnpm --filter vii-docs dev"
  },
  "devDependencies": {
    "bumpp": "^11.1.0",
    "simple-git-hooks": "^2.11.1",
    "typescript": "^5.7.2",
    "vite-plus": "^0.1.24"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec vp check --fix && git add $(git diff --name-only --cached)"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.15.0"
  },
  "packageManager": "pnpm@9.15.0"
}
