{
  "name": "vii",
  "license": "MIT",
  "author": "vyron",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vfiee/project-boilerplate.git"
  },
  "type": "module",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "postinstall": "simple-git-hooks",
    "format": "vp check --fix",
    "lint": "vp check",
    "dev": "pnpm -r --parallel --filter='./packages/cli' run dev",
    "build": "pnpm -r --filter='./packages/*' run build",
    "typecheck": "vp check --no-fmt --no-lint"
  },
  "devDependencies": {
    "simple-git-hooks": "^2.11.1",
    "typescript": "^5.7.2",
    "vite-plus": "^0.1.24"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec vp check --fix"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.15.0"
  },
  "packageManager": "pnpm@9.15.0"
}
